# Skopiuj ten plik jako .env i wypełnij wartościami
# .env jest w .gitignore — nie wpadnie do GitHuba

# Wymagane dla AI opisu zmian wizualnych
# Generujesz tu: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Opcjonalne — alert na Google Chat
# Tworzysz w Space → Apps & integrations → Add webhooks → Copy URL
GOOGLE_CHAT_WEBHOOK_URL=

# Opcjonalne — email przez Resend
# Generujesz tu: https://resend.com/api-keys
RESEND_API_KEY=

# Opcjonalne — alert na Telegram
# 1) W Telegramie napisz do @BotFather → /newbot → skopiuj token niżej
# 2) Wyślij dowolną wiadomość do swojego nowego bota
# 3) Otwórz w przeglądarce: https://api.telegram.org/bot<TWOJ_TOKEN>/getUpdates
#    Znajdź pole "chat":{"id":...} — to TELEGRAM_CHAT_ID (dla grup może być ujemny)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
